@base_url = http://localhost:5000/api
@token = YOUR_ACCESS_TOKEN_HERE
@employee_id = 1

### 1. Get Full Profile (Include new fields)
GET {{base_url}}/employees/{{employee_id}}/full-profile
Authorization: Bearer {{token}}

### 2. Update Basic Info
PUT {{base_url}}/employees/{{employee_id}}/basic-info
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "fullName": "Nguyễn Văn A (Updated)",
    "birthDate": "1990-01-01",
    "genderCode": "MALE",
    "maritalStatusCode": "SINGLE",
    "departmentId": 1,
    "jobTitleId": 1,
    "branchId": 1,
    "startDate": "2024-01-01",
    "avatar": "https://example.com/avatar.jpg"
}

### 3. Update Contact Info
PUT {{base_url}}/employees/{{employee_id}}/contact
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "phone": "0987654321",
    "homePhone": "0243123456",
    "email": "vana@example.com",
    "workEmail": "a.nv@company.com",
    "facebook": "fb.com/van-a"
}

### 4. Update Identity Info
PUT {{base_url}}/employees/{{employee_id}}/identity
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "identityNumber": "123456789012",
    "identityIssueDate": "2020-05-15",
    "identityIssuePlace": "CA Hà Nội",
    "passport": "B1234567",
    "nationality": "Việt Nam",
    "ethnicity": "Kinh",
    "religion": "Không"
}
