@baseUrl = http://localhost:5122/api
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..1455555555555555555555555555555555555555

### Get all branches
GET {{baseUrl}}/branches
Authorization: Bearer {{token}}

### Get a branch by ID
GET {{baseUrl}}/branches/1
Authorization: Bearer {{token}}

### Create a new branch
POST {{baseUrl}}/branches
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Chi nhánh Hà Nội",
  "code": "HN01",
  "address": "123 Cầu Giấy, Hà Nội"
}

### Update a branch
PUT {{baseUrl}}/branches/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Chi nhánh Hà Nội (Cập nhật)",
  "address": "456 Trần Duy Hưng, Hà Nội"
}

### Delete a branch
DELETE {{baseUrl}}/branches/1
Authorization: Bearer {{token}}

### Get all departments
GET {{baseUrl}}/departments
Authorization: Bearer {{token}}

### Get all job titles
GET {{baseUrl}}/jobtitles
Authorization: Bearer {{token}}

### Get all regions
GET {{baseUrl}}/regions
Authorization: Bearer {{token}}
