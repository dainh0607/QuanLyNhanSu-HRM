### Employee API Tests

@baseUrl = http://localhost:5122
@contentType = application/json

############################################################
### 1. Đăng nhập Quản lý để lấy Token
############################################################

# @name managerLogin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "manager.test@company.com",
  "password": "ManagerPassword123"
}

###

@authToken = {{managerLogin.response.body.idToken}}


############################################################
### 2. Thêm mới nhân viên
############################################################

# @name createEmployee
POST {{baseUrl}}/api/employees
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "employeeCode": "EMP_TEST_02",
  "fullName": "Nguyễn Văn Test Lan 2",
  "email": "nvtest2@company.com",
  "phone": "0987654321",
  "departmentId": 1,
  "jobTitleId": 1,
  "branchId": 1,
  "startDate": "2026-03-28T00:00:00Z",
  "password": "123456789"
}

###

############################################################
### 3. Liệt kê danh sách nhân viên (Phân trang & Tìm kiếm)
############################################################

GET {{baseUrl}}/api/employees?pageNumber=1&pageSize=10&searchTerm=Nguyễn
Authorization: Bearer {{authToken}}

###

############################################################
### 4. Lấy chi tiết nhân viên theo ID
############################################################

@employeeId = {{createEmployee.response.body.id}}

GET {{baseUrl}}/api/employees/{{employeeId}}
Authorization: Bearer {{authToken}}

###

############################################################
### 5. Cập nhật thông tin nhân viên
############################################################

PUT {{baseUrl}}/api/employees/{{employeeId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "fullName": "Nguyễn Văn Test Updated",
  "email": "nvtest_upd@company.com",
  "phone": "0123456789",
  "isActive": true,
  "isResigned": false
}

###

############################################################
### 6. Xóa nhân viên (Soft Delete)
############################################################

DELETE {{baseUrl}}/api/employees/{{employeeId}}
Authorization: Bearer {{authToken}}

###

############################################################
### 7. Kiểm tra lại sau khi xóa (Phải trả về is_active = false)
############################################################

GET {{baseUrl}}/api/employees/{{employeeId}}
Authorization: Bearer {{authToken}}

###
