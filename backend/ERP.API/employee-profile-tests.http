@baseUrl = http://localhost:5122/api
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..1455555555555555555555555555555555555555

### Get full employee profile
GET {{baseUrl}}/employees/1/full-profile
Authorization: Bearer {{token}}

### Update bank accounts
PUT {{baseUrl}}/employees/1/bank-accounts
Authorization: Bearer {{token}}
Content-Type: application/json

[
  {
    "accountHolder": "NGUYEN VAN A",
    "accountNumber": "123456789",
    "bankName": "Vietcombank",
    "branch": "Chi nhánh Ba Đình"
  }
]

### Update health record
PUT {{baseUrl}}/employees/1/health-record
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "height": 175.5,
  "weight": 70.2,
  "bloodType": "O",
  "congenitalDisease": "None",
  "chronicDisease": "None",
  "healthStatus": "Good",
  "checkDate": "2024-03-29"
}

